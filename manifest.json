{
  "manifest_version": 3,
  "name": "Skippy M.D.",
  "version": "1.0.0",
  "description": "A full-featured Markdown viewer with syntax highlighting, math equations, diagrams, and more",
  "permissions": [
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "file:///*",
    "*://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["viewer.html", "viewer.js", "styles/*", "lib/*", "lib/fonts/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
